# shellcheck policy for serial_nexus validation scripts (post-1.0 §9.4 / design
# §16.5). shellcheck runs green across scripts/ on every push; these three codes are
# disabled because they are systemic false-positives for this codebase's idioms, not
# because the findings were papered over:
#
#   SC1091  "Not following: <file> was not specified as input"  — every script
#           sources scripts/lib/*.sh by a runtime-computed path shellcheck cannot
#           resolve statically. The sourced files are themselves checked directly.
#   SC2164  "Use 'cd ... || exit'"                              — the scripts cd to
#           a REPO_ROOT derived from BASH_SOURCE, which cannot fail in practice; the
#           41 call sites would only gain ceremony.
#   SC2329  "This function is never invoked"                    — cleanup handlers
#           are invoked indirectly via `trap cleanup EXIT`, which shellcheck cannot see.
disable=SC1091,SC2164,SC2329
